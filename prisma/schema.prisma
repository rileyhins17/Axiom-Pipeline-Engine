generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id            Int      @id @default(autoincrement())
  businessName  String
  niche         String
  city          String
  category      String?
  address       String?
  phone         String?
  email         String?
  socialLink    String?
  rating        Float?
  reviewCount   Int?
  websiteStatus String?
  contactName   String?
  tacticalNote  String?
  createdAt     DateTime @default(now())
}
