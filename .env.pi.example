# ──────────────────────────────────────────────────────────
# The Omniscient — Raspberry Pi / Self-Hosted Environment
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All values below are read via process.env on bare Node.js.

# App URL — set to your Cloudflare Tunnel hostname or localhost
APP_BASE_URL=http://localhost:3000

# Auth secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-at-least-64-random-characters

# Comma-separated emails allowed to sign up
AUTH_ALLOWED_EMAILS=your-email@example.com

# Comma-separated emails with admin privileges (scrape, export, delete)
AUTH_ADMIN_EMAILS=your-email@example.com

# Google Gemini API key for AI enrichment (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Path to the local SQLite database file
DATABASE_PATH=./data/omniscient.db

# ── Rate Limits ──────────────────────────────────────────
# Set RATE_LIMIT_MAX_SCRAPE=0 for unlimited scrapes (no CF quota issues!)
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_EXPORT=50
RATE_LIMIT_MAX_SCRAPE=0
SCRAPE_CONCURRENCY_LIMIT=1
SCRAPE_TIMEOUT_MS=300000
